# Создать бота: @BotFather → /newbot → получить токен
# BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Для деплоя на Render.com (вебхуки):
# 1. Зарегистрироваться на render.com (через GitHub)
# 2. Залить этот проект на GitHub
# 3. Создать Web Service → Connect repo → Start command: python bot.py
# 4. Добавить переменные: BOT_TOKEN, RENDER_URL
# RENDER_URL=https://твой-бот.onrender.com
